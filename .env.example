ENVIRONMENT=development
HOST=0.0.0.0
PORT=8080

DATABASE_URL=postgres://wt-admin:password@localhost:5432/wt_data
DATABASE_SSL=false

PUBLIC_BASE_URL=https://tg.example.com
WEBHOOK_PATH_PREFIX=/webhooks/telegram

DELIVERY_POLL_INTERVAL=5
DELIVERY_BATCH_SIZE=20
BOT_REQUEST_TIMEOUT=20
MAX_JOB_ATTEMPTS=5
REMINDER_POLL_INTERVAL=60
REMINDER_BATCH_SIZE=40
REMINDER_TIMEZONE=Europe/Kyiv
REMINDER_SCHEDULE_HOUR=10
REMINDER_SCHEDULE_MINUTE=0

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=WTmelon
SMTP_USE_TLS=true
SMTP_USE_SSL=false
